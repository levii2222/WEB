<?php


function factorial($n) {
    if ($n < 0) {
        return "Factorial not defined for negative numbers";
    }

    $fact = 1;

    for ($i = 1; $i <= $n; $i++) {
        $fact = $fact * $i;
    }

    return $fact;
}


if (isset($_POST['num'])) {

