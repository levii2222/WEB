$username = $_POST['username'];
$password = $_POST['password'];

// Use correct variable name
$length = strlen($password) > 8;
$hasupper = preg_match("/[A-Z]/", $password);
$haslower = preg_match("/[a-z]/", $password);
$hasspe = preg_match("/[^a-zA-Z0-9]/", $password);
$hasno = preg_match("/[0-9]/", $password);

echo "<h2>Password validation result</h2>";

if ($length && $hasupper && $haslower && $hasspe && $hasno) {
    echo "<div style='color:green;'>You entered a strong password</div>";
} else {
    echo "<div style='color:red;'>Please enter a complex password</div>";
}
