phpscript.php

<?php

// Check form submission
if (isset($_POST['operation'])) {

    $str1 = $_POST['str1'];
    $str2 = $_POST['str2'];
    $operation = $_POST['operation'];

    echo "<h2>Result</h2>";

    switch ($operation) {

        case "compare":
            if ($str1 == $str2) {
                echo "Both strings are equal.";
            } else {
                echo "Strings are NOT equal.";
            }
            break;

        case "upper":
            echo "Uppercase String: " . strtoupper($str1);
            break;

        case "lower":
            echo "Lowercase String: " . strtolower($str1);
            break;

        default:
            echo "Invalid Operation!";
    }

} else {
    echo "Please select an operation!";
}
?>
