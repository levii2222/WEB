<?php

function calculateCylinder($r, $h)
{
    $area = 2 * pi() * $r * ($r + $h); // Surface Area
    $volume = pi() * $r * $r * $h;     // Volume

    return array($area, $volume);
}

// Check if form is submitted
if (isset($_POST['radius']) && isset($_POST['height'])) {

    $radius = $_POST['radius'];
    $height = $_POST['height'];

    // Validate numeric input
    if (!is_numeric($radius) || !is_numeric($height)) {
        echo "Please enter valid numbers!";
        exit();
    }

    list($area, $volume) = calculateCylinder($radius, $height);

    echo "<h2>Cylinder Results</h2>";
    echo "Radius: " . $radius . "<br><br>";
    echo "Height: " . $height . "<br><br>";
    echo "Surface Area: " . $area . "<br><br>";
    echo "Volume: " . $volume;

} else {
    echo "Please submit the form first!";
}
?>

